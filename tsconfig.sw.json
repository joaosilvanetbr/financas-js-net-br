{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "WebWorker", "DOM"],
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/sw.ts"]
}
